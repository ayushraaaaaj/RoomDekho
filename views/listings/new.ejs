<% layout("/layouts/boilerplate") %>
<body>
    <div class="row">
        <div class="col-8 offset-2">
            <br><br>
            <h3>Create a new listing</h3>
            <form method="POST" action="/listings" novalidate class="needs-validation">
                <div class="mb-3">
                    <lable for="title" class="form-label">Title</lable>
                    <input name="listing[title]" placeholder="enter title" type="text" class="form-control" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">
                        Please enter a valid title
                    </div>
                </div>
                <div class="mb-3">
                    <lable for="description" class="form-label">Description</lable>
                    <textarea name="listing[description]" placeholder="enter description" class="form-control" required></textarea>
                    <div class="invalid-feedback">
                        Please enter a valid description
                    </div>
                </div>
                <div class="mb-3">
                    <lable for="image" class="form-label">Image Link (image address)</lable>
                    <input name="listing[image]" placeholder="enter image URL/Link" type="text" class="form-control" required>
                    <div class="invalid-feedback">
                        Please a valid image URL/Link
                    </div>
                </div>
                <div class="row">
                     <div class="mb-3 col-4">
                        <lable for="price" class="form-label">Price</lable>
                        <input name="listing[price]" placeholder="enter the price" type="number" class="form-control" required>
                        <div class="invalid-feedback">
                            Please enter a valid price
                        </div>
                    </div>
                    <div class="mb-3 col-8">
                        <lable for="country" class="form-label">Country</lable>
                        <input name="listing[country]" placeholder="enter country" type="text" class="form-control" required>
                        <div class="invalid-feedback">
                            Please enter a valid country
                        </div>
                    </div>
                </div>
               
                <div class="mb-3">
                    <lable for="location" class="form-label">Location</lable>
                    <input name="listing[location]" placeholder="enter location" type="text" class="form-control" required>
                    <div class="invalid-feedback">
                        Please enter a valid location
                    </div>
                </div>
                <br>
                <button class="btn btn-dark add-btn">Add</button>
            </form>
            <br><br>
        </div>
    </div>
</body>